# Server
RYNCTL_PORT=8080
RYNCTL_SECRET=change-me-to-a-random-secret-string
RYNCTL_LOG_LEVEL=INFO

# Security
RYNCTL_SESSION_DAYS=7
RYNCTL_MAX_LOGIN_ATTEMPTS=5
RYNCTL_LOCKOUT_MINUTES=15
RYNCTL_RATE_LIMIT_RPM=120

# Retry on failure (0 = disabled)
RYNCTL_RETRY_MAX=0
RYNCTL_RETRY_DELAY=30

# Webhook notifications (empty = disabled)
# RYNCTL_WEBHOOK_URL=https://hooks.slack.com/services/xxx
# RYNCTL_WEBHOOK_EVENTS=failure  # failure, success, or all

# Prometheus metrics
RYNCTL_METRICS=true

# Data directory (default: /data in Docker, ./data locally)
# RYNCTL_DATA_DIR=/data
